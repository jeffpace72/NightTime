{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "PublicReadAudioAndIcons",
      "Effect": "Allow",
      "Principal": "*",
      "Action": "s3:GetObject",
      "Resource": [
        "arn:aws:s3:::nighttime-skill-audio/audio/*",
        "arn:aws:s3:::nighttime-skill-audio/icons/*"
      ]
    }
  ]
}
