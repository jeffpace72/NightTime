{
  "type": "APL",
  "version": "2024.3",
  "theme": "dark",
  "mainTemplate": {
    "parameters": ["payload"],
    "items": [
      {
        "type": "Container",
        "width": "100vw",
        "height": "100vh",
        "items": [
          {
            "type": "Image",
            "width": "100vw",
            "height": "100vh",
            "position": "absolute",
            "scale": "best-fill",
            "source": "${payload.data.backgroundUrl}"
          },
          {
            "type": "Container",
            "width": "100vw",
            "height": "100vh",
            "position": "absolute",
            "items": [
              {
                "type": "Container",
                "grow": 1
              },
              {
                "type": "Container",
                "paddingLeft": "5vw",
                "paddingRight": "5vw",
                "paddingBottom": "8vh",
                "items": [
                  {
                    "type": "Text",
                    "text": "${payload.data.title}",
                    "style": "textStyleDisplay4",
                    "color": "white",
                    "fontSize": "7vh",
                    "fontWeight": "bold",
                    "textAlign": "center"
                  },
                  {
                    "type": "Text",
                    "text": "${payload.data.subtitle}",
                    "color": "rgba(255,255,255,0.8)",
                    "fontSize": "3vh",
                    "textAlign": "center",
                    "paddingTop": "2vh"
                  }
                ]
              }
            ]
          }
        ]
      }
    ]
  }
}
