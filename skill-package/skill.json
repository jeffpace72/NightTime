{
  "manifest": {
    "publishingInformation": {
      "locales": {
        "en-US": {
          "name": "Night Time",
          "summary": "Play relaxing ambient sounds: rain, thunderstorm, ocean waves, jungle, city sounds, and reality check.",
          "description": "Night Time plays soothing ambient sounds to help you relax and fall asleep. Choose from rain, thunderstorm, ocean waves, jungle, city sounds, or reality check. All sounds loop seamlessly until you say stop.",
          "examplePhrases": [
            "Alexa, open night time",
            "Alexa, ask night time to play rain",
            "Alexa, ask night time to play ocean waves",
            "Alexa, ask night time to play reality check"
          ],
          "keywords": [
            "sleep",
            "ambient",
            "relaxing",
            "rain",
            "nature",
            "white noise",
            "sounds"
          ],
          "smallIconUri": "https://nighttime-skill-audio.s3.amazonaws.com/icons/icon_108_A2Z.png",
          "largeIconUri": "https://nighttime-skill-audio.s3.amazonaws.com/icons/icon_512_A2Z.png"
        }
      },
      "isAvailableWorldwide": false,
      "testingInstructions": "Open the skill and say 'play rain' to test audio playback. Say 'stop' to end.",
      "category": "SELF_IMPROVEMENT",
      "distributionCountries": [
        "US"
      ]
    },
    "apis": {
      "custom": {
        "interfaces": [
          {
            "type": "AUDIO_PLAYER"
          },
          {
            "type": "ALEXA_PRESENTATION_APL",
            "supportedViewports": [
              {
                "mode": "HUB",
                "shape": "ROUND",
                "minWidth": 480,
                "maxWidth": 480,
                "minHeight": 480,
                "maxHeight": 480
              },
              {
                "mode": "HUB",
                "shape": "RECTANGLE",
                "minWidth": 960,
                "maxWidth": 1280,
                "minHeight": 480,
                "maxHeight": 800
              },
              {
                "mode": "HUB",
                "shape": "RECTANGLE",
                "minWidth": 1920,
                "maxWidth": 1920,
                "minHeight": 1080,
                "maxHeight": 1080
              }
            ]
          }
        ],
        "endpoint": {
          "uri": "arn:aws:lambda:us-east-1:875378932855:function:ask-nighttime-default-default-1775318183129"
        }
      }
    },
    "manifestVersion": "1.0"
  }
}